{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/product/:id", "destination": "/api/product-og/:id" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-orders",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/backup-db",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/refresh-ae-token",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/enrich-products",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/process-build-queue",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/rebuild-product-variants",
      "schedule": "* * * * *"
    }
  ]
}
