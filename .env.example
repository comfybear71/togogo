# ── Required for auth & database ──
JWT_SECRET=your-jwt-secret-here
POSTGRES_URL=postgres://user:password@host:5432/dbname

# Google OAuth (required for "Sign in with Google")
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://togogo.me/api/auth/google/callback

# Vercel API (required for store subdomain provisioning)
# VERCEL_TOKEN=your-vercel-api-token
# VERCEL_PROJECT_ID=your-vercel-project-id

# Stripe (client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Backend API (for server-side operations)
# STRIPE_SECRET_KEY=sk_test_your-key
# STRIPE_WEBHOOK_SECRET=whsec_your-key
# ANTHROPIC_API_KEY=sk-ant-your-key
# ALIEXPRESS_APP_KEY=your-app-key
# ALIEXPRESS_APP_SECRET=your-app-secret
# CJ_DROPSHIPPING_API_KEY=your-key
# PRINTFUL_API_KEY=your-key
# PRINTIFY_API_KEY=your-key
# GOOTEN_RECIPE_ID=your-recipe-id
# GOOTEN_PARTNER_BILLING_KEY=your-billing-key
# SENDGRID_API_KEY=SG.your-key
# AUSPOST_API_KEY=your-key
# EASYPOST_API_KEY=your-key
# ETSY_API_KEY=your-keystring
# EBAY_CLIENT_ID=your-client-id
# EBAY_CLIENT_SECRET=your-client-secret
# EBAY_ENVIRONMENT=SANDBOX
# AMAZON_SP_APP_ID=amzn1.sp.solution.xxx
# AMAZON_SP_CLIENT_ID=amzn1.application-oa2-client.xxx
# AMAZON_SP_CLIENT_SECRET=your-lwa-client-secret
# TIKTOK_APP_KEY=your-app-key
# TIKTOK_APP_SECRET=your-app-secret
# DEEPL_API_KEY=your-key
# UPSTASH_REDIS_URL=your-url
# UPSTASH_REDIS_TOKEN=your-token
